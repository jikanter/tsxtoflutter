{
  "name": "@tsxtoflutter/orchestrator",
  "version": "0.0.0",
  "private": true,
  "description": "File watcher: TSX/MDX → ingest → codegen subprocess → Flutter VM-service hot-restart.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc --noEmit",
    "dev": "bun run src/index.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@tsxtoflutter/ingest": "workspace:*",
    "@tsxtoflutter/ir": "workspace:*",
    "chokidar": "^4.0.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
